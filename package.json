{
  "name": "greenlight-app-reviews-mcp",
  "version": "1.0.0",
  "description": "Greenlight App Review Intelligence MCP Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "scrape": "node scripts/scrape.js",
    "start": "node --experimental-wasm-modules dist/index.js",
    "start:all": "npm run scrape && npm run start",
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "verify": "tsc --noEmit && vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "app-store-scraper": "^0.18.0",
    "async-retry": "^1.3.3",
    "dotenv": "^17.3.1",
    "openai": "^6.22.0",
    "p-limit": "^6.1.0",
    "papaparse": "^5.4.1",
    "voy-search": "^0.6.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/async-retry": "^1.4.8",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.14",
    "@vitest/coverage-v8": "^1.6.1",
    "google-play-scraper": "^10.1.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
